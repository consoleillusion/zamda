    "ramda": "^0.31.3",
    "sanctuary": "^3.1.0",
    "sanctuary-def": "^0.22.0",
    "sanctuary-type-classes": "^13.0.0",
    "sanctuary-type-identifiers": "^4.0.0"
  }
